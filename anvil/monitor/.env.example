# anvil-monitor environment template (v5 Phase 1a).
# The real file is .env.systemd at /home/vault-reporter/anvil-monitor/ on the
# VPS — gitignored, never committed, never hand-edited (Mac -> GitHub -> VPS).
# systemd EnvironmentFile format: KEY=value, one per line, no quoting needed.

# The dedicated ANVIL Telegram bot token (bot id 8876582427). Key name is
# TELEGRAM_BOT_TOKEN to match the Mac .env convention (Step 0 Q-A5), NOT
# ANVIL_BOT_TOKEN. UNUSED in Phase 1a (the monitor is idle; no Telegram until
# Phase 1b) — provisioned now so the VPS .env.systemd is complete for 1b.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# The operations-ledger SQLite path (the monitor's only persistent state).
ANVIL_OPS_DB_PATH=/home/vault-reporter/anvil-ops.db

# Append-target log file (also set via the systemd unit's StandardOutput).
LOG_PATH=/home/vault-reporter/anvil-monitor.log

# --- v5 Phase 1c: the Sentry trigger (item D) ------------------------------
# The Sentry poll is GATED on SENTRY_PROJECT — unset (the default) means the
# monitor never calls Sentry. DEFERRED in Phase 1c (no Sentry account; the live
# probe is a Phase 2 carry-forward). Provision these to activate it (no code
# change): the project slug, the REST token (sentry:read), and the
# deterministic filter (severity threshold + an optional title noise-regex).
SENTRY_PROJECT=
SENTRY_API_TOKEN=
SENTRY_ORG=
SENTRY_MIN_LEVEL=error
SENTRY_NOISE_REGEX=
# Poll cadence (seconds); 5-min lean.
ANVIL_SENTRY_POLL_S=300

# --- v5 Phase 1c: the mode-guard (item F) ----------------------------------
# An active running_builds row older than this many hours is treated as STALE
# (a build whose completion SSH-write never landed) → the monitor escalates
# once rather than blocking triggers forever. The active/complete rows are
# written by the Mac orchestrator over SSH (the reverse channel); no Mac-side
# vars live here.
ANVIL_BUILD_STALENESS_H=6
