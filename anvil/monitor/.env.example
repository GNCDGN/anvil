# anvil-monitor environment template (v5 Phase 1a).
# The real file is .env.systemd at /home/vault-reporter/anvil-monitor/ on the
# VPS — gitignored, never committed, never hand-edited (Mac -> GitHub -> VPS).
# systemd EnvironmentFile format: KEY=value, one per line, no quoting needed.

# The dedicated ANVIL Telegram bot token (bot id 8876582427). Key name is
# TELEGRAM_BOT_TOKEN to match the Mac .env convention (Step 0 Q-A5), NOT
# ANVIL_BOT_TOKEN. UNUSED in Phase 1a (the monitor is idle; no Telegram until
# Phase 1b) — provisioned now so the VPS .env.systemd is complete for 1b.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# The operations-ledger SQLite path (the monitor's only persistent state).
ANVIL_OPS_DB_PATH=/home/vault-reporter/anvil-ops.db

# Append-target log file (also set via the systemd unit's StandardOutput).
LOG_PATH=/home/vault-reporter/anvil-monitor.log
