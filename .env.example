ANTHROPIC_API_KEY=sk-ant-...                       # for the Planner
TELEGRAM_BOT_TOKEN=...                              # ANVIL's own dedicated bot (separate bot from Veronica, same chat_id)
TELEGRAM_CHAT_ID=...                                # same chat ID Veronica uses
VAULT_PATH=~/vaults/second-brain                    # for vault_ops (Phase 4)
PLANNER_MODEL=claude-opus-4-7                       # pinnable; default Opus 4.7
CODER_TIMEOUT_SECONDS=600
PLANNER_TIMEOUT_SECONDS=120
ANVIL_DEFER_WINDOW_SECONDS=300                      # how long Veronica defers reserved tokens after an [ANVIL] message
VPS_HOST=                                            # VPS deployment — required when running briefs with vps_deploy: yes
VPS_USER=root                                        # SSH user on VPS; default root matches Veronica's deploy pattern
# MOCKED_PLANNER=0                                   # v2 calibration only — enable MockedPlanner subclass (anvil/mocked.py)
# MOCKED_CODER=0                                     # v2 calibration only — enable MockedCoder subclass (anvil/mocked.py)
# ANVIL_RUN_ID_OVERRIDE=                             # v2 calibration only — calibration_runner injects per-task run_id ("T1-doc-edit" etc.)
# MOCKED_TASK_ID=                                    # v2 calibration only — fixture lookup key for MockedPlanner/MockedCoder
# MOCKED_PLANNER_JITTER_MS=0                         # v2 calibration only — simulated latency per Planner call
# MOCKED_CODER_JITTER_MS=0                           # v2 calibration only — simulated latency per Coder invocation
